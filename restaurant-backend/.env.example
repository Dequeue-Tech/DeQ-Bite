NODE_ENV=development
PORT=5000

# Frontend URL
FRONTEND_URL=http://localhost:3000
BASE_DOMAIN=example.com

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/restaurant_db"

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Paytm (optional)
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=

# PhonePe (optional)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# App Configuration
APP_NAME=Restaurant Online Ordering
APP_URL=http://localhost:5000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./public/uploads

# Backblaze B2 Cloud Storage Configuration
# Get these from your B2 account: https://secure.backblaze.com/b2_buckets.htm
B2_APPLICATION_KEY_ID=your_b2_application_key_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_ID=your_b2_bucket_id
B2_BUCKET_NAME=your-bucket-name
# Optional: Custom domain for public URLs (e.g., https://cdn.yourdomain.com)
# If not set, will use B2's native public URL format
# B2_CUSTOM_DOMAIN=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ENCRYPTION_KEY=your-32-character-encryption-key-here
API_KEY=your-api-key-for-internal-services
