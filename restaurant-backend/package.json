{
  "name": "restaurant-backend",
  "version": "1.0.0",
  "description": "Restaurant backend API server with secure payment processing",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && tsc-alias",
    "start": "node ./dist/server.js",
    "postbuild": "mkdir dist\\public 2>nul & robocopy public dist\\public /E 2>nul & exit 0",
    "lint": "eslint src/**/*.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@types/multer": "^1.4.12",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.0",
    "get-stream": "^9.0.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "prisma": "^6.16.2",
    "razorpay": "^2.9.6",
    "tsconfig-paths": "^4.2.0",
    "twilio": "^5.10.0",
    "uuid": "^13.0.0",
    "winston": "^3.14.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.17",
    "@types/nodemailer": "^7.0.1",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "eslint": "^9",
    "ncp": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "keywords": [
    "restaurant",
    "api",
    "backend",
    "express",
    "typescript",
    "razorpay",
    "payments",
    "invoice"
  ],
  "author": "Restaurant App",
  "license": "MIT"
}
