// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?  @unique
  name      String
  password  String
  role      UserRole @default(CUSTOMER)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  restaurantUsers RestaurantUser[]
  
  @@map("users")
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  subdomain   String   @unique
  email       String?
  phone       String?
  address     String?
  active      Boolean  @default(true)
  paymentCollectionTiming PaymentCollectionTiming @default(AFTER_MEAL)
  cashPaymentEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories  Category[]
  menuItems   MenuItem[]
  tables      Table[]
  orders      Order[]
  coupons     Coupon[]
  users       RestaurantUser[]

  @@map("restaurants")
}

model RestaurantUser {
  id            String   @id @default(cuid())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  role          RestaurantRole @default(ADMIN)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([restaurantId, userId])
  @@map("restaurant_users")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  image       String?
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  menuItems   MenuItem[]
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  
  @@unique([restaurantId, name])
  @@map("categories")
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String?
  pricePaise  Int
  image       String?
  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  available   Boolean     @default(true)
  preparationTime Int     @default(15) // in minutes
  ingredients String[]    @default([])
  allergens   String[]    @default([])
  isVeg       Boolean     @default(true)
  isVegan     Boolean     @default(false)
  isGlutenFree Boolean    @default(false)
  spiceLevel  SpiceLevel  @default(MILD)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  
  @@map("menu_items")
}

model Table {
  id       String  @id @default(cuid())
  number   Int
  capacity Int
  location String? // e.g., "Window side", "Garden area"
  active   Boolean @default(true)
  orders   Order[]
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  
  @@unique([restaurantId, number])
  @@map("tables")
}

model Order {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  table         Table       @relation(fields: [tableId], references: [id])
  tableId       String
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  subtotalPaise Int
  taxPaise      Int
  discountPaise Int         @default(0)
  totalPaise    Int
  paymentId     String?     // Payment order/reference ID
  paymentTransactionId String? // Payment transaction ID (gateway payment id)
  paymentProvider PaymentProvider @default(RAZORPAY)
  paymentStatus PaymentStatus @default(PENDING)
  paymentCollectionTiming PaymentCollectionTiming @default(AFTER_MEAL)
  specialInstructions String?
  estimatedTime Int?        // in minutes
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  invoice       Invoice?
  coupon        Coupon?     @relation(fields: [couponId], references: [id])
  couponId      String?
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String
  
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
  quantity   Int
  pricePaise Int      // Price at time of order (in paise)
  notes      String?  // Special requests for this item
  
  @@map("order_items")
}

model Invoice {
  id            String        @id @default(cuid())
  order         Order         @relation(fields: [orderId], references: [id])
  orderId       String        @unique
  invoiceNumber String        @unique
  issuedAt      DateTime      @default(now())
  sentVia       InvoiceMethod[]
  emailSent     Boolean       @default(false)
  smsSent       Boolean       @default(false)
  pdfPath       String?       // Path to generated PDF (deprecated)
  pdfData       Bytes?        // PDF data stored as binary in database
  pdfName       String?       // Name of the PDF file
  
  @@map("invoices")
}

model Coupon {
  id            String      @id @default(cuid())
  code          String
  description   String?
  type          CouponType
  value         Int
  maxDiscountPaise Int?
  minOrderPaise Int?
  usageLimit    Int?
  usageCount    Int         @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId  String
  orders        Order[]

  @@unique([restaurantId, code])
  @@map("coupons")
}

enum UserRole {
  CUSTOMER
  OWNER
  ADMIN
  STAFF
}

enum RestaurantRole {
  OWNER
  ADMIN
  STAFF
}

enum CouponType {
  PERCENT
  FIXED
}

enum PaymentProvider {
  RAZORPAY
  PAYTM
  PHONEPE
  CASH
}

enum PaymentCollectionTiming {
  BEFORE_MEAL
  AFTER_MEAL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum SpiceLevel {
  NONE
  MILD
  MEDIUM
  HOT
  EXTRA_HOT
}

enum InvoiceMethod {
  EMAIL
  SMS
}
