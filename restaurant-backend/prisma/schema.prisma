generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  phone           String?          @unique
  name            String
  password        String
  role            UserRole         @default(CUSTOMER)
  verified        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orders          Order[]
  restaurantUsers RestaurantUser[]

  @@map("users")
}

model Restaurant {
  id                      String                  @id @default(cuid())
  name                    String
  slug                    String                  @unique
  subdomain               String                  @unique
  status                  OnboardingStatus        @default(PENDING_APPROVAL)
  suspendedReason         String?
  email                   String?
  phone                   String?
  address                 String?
  city                    String?
  state                   String?
  country                 String?
  cuisine                 String?
  cuisineTypes            String[]                @default([])
  logoUrl                 String?
  bannerUrl               String?
  googleReviewUrl         String?
  gstNumber               String?
  gstLegalName            String?
  bankAccountName         String?
  bankAccountNumber       String?
  bankIfsc                String?
  bankName                String?
  commissionRate          Int                     @default(0)
  commissionRateBps       Int                     @default(0)
  approvedAt              DateTime?
  approvedByUserId        String?
  onboardingStatus        OnboardingStatus        @default(PENDING_APPROVAL)
  active                  Boolean                 @default(true)
  paymentCollectionTiming PaymentCollectionTiming @default(AFTER_MEAL)
  cashPaymentEnabled      Boolean                 @default(true)
  acceptedPaymentMethods  String[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  categories              Category[]
  coupons                 Coupon[]
  popularDishes           PopularDish[]
  menuItems               MenuItem[]
  offers                  Offer[]
  orders                  Order[]
  users                   RestaurantUser[]
  tables                  Table[]
  earnings                Earning[]              @relation("earnings")

  @@map("restaurants")
}

model RestaurantUser {
  id           String         @id @default(cuid())
  restaurantId String
  userId       String
  role         RestaurantRole @default(ADMIN)
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, userId])
  @@index([restaurantId, userId, active])
  @@map("restaurant_users")
}

model Category {
  id           String     @id @default(cuid())
  name         String
  description  String?
  image        String?
  active       Boolean    @default(true)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, active, sortOrder])
  @@map("categories")
}

model MenuItem {
  id              String      @id @default(cuid())
  name            String
  description     String?
  image           String?
  categoryId      String
  available       Boolean     @default(true)
  preparationTime Int         @default(15)
  ingredients     String[]    @default([])
  allergens       String[]    @default([])
  isVeg           Boolean     @default(true)
  isVegan         Boolean     @default(false)
  isGlutenFree    Boolean     @default(false)
  spiceLevel      SpiceLevel  @default(MILD)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  pricePaise      Int
  restaurantId    String
  category        Category    @relation(fields: [categoryId], references: [id])
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  popularDishes   PopularDish[]

  @@map("menu_items")
  @@index([restaurantId, available])
  @@index([restaurantId, categoryId])
}

model PopularDish {
  id           String     @id @default(cuid())
  restaurantId String
  menuItemId   String
  rank         Int        @default(0)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, menuItemId])
  @@map("popular_dishes")
}

model Table {
  id           String     @id @default(cuid())
  number       Int
  capacity     Int
  location     String?
  active       Boolean    @default(true)
  restaurantId String
  orders       Order[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, number])
  @@index([restaurantId, active])
  @@map("tables")
}

model Order {
  id                      String                  @id @default(cuid())
  userId                  String
  tableId                 String
  status                  OrderStatus             @default(PENDING)
  paymentId               String?
  paymentStatus           PaymentStatus           @default(PENDING)
  specialInstructions     String?
  estimatedTime           Int?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  couponId                String?
  discountPaise           Int                     @default(0)
  paymentCollectionTiming PaymentCollectionTiming @default(AFTER_MEAL)
  paymentProvider         PaymentProvider         @default(RAZORPAY)
  paymentTransactionId    String?
  paidAmountPaise         Int                     @default(0)
  dueAmountPaise          Int                     @default(0)
  restaurantId            String
  subtotalPaise           Int
  taxPaise                Int
  totalPaise              Int
  invoice                 Invoice?
  items                   OrderItem[]
  coupon                  Coupon?                 @relation(fields: [couponId], references: [id])
  restaurant              Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table                   Table                   @relation(fields: [tableId], references: [id])
  user                    User                    @relation(fields: [userId], references: [id])
  payments                Payment[]

  @@map("orders")
  @@index([restaurantId, createdAt])
  @@index([restaurantId, userId, createdAt])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, paymentStatus, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  notes      String?
  pricePaise Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Invoice {
  id            String          @id @default(cuid())
  orderId       String          @unique
  invoiceNumber String          @unique
  issuedAt      DateTime        @default(now())
  sentVia       InvoiceMethod[]
  emailSent     Boolean         @default(false)
  smsSent       Boolean         @default(false)
  pdfPath       String?
  pdfData       Bytes?
  pdfName       String?
  order         Order           @relation(fields: [orderId], references: [id])

  @@map("invoices")
  @@index([issuedAt])
}

model Coupon {
  id               String     @id @default(cuid())
  code             String
  description      String?
  type             CouponType
  value            Int
  maxDiscountPaise Int?
  minOrderPaise    Int?
  usageLimit       Int?
  usageCount       Int        @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders           Order[]

  @@unique([restaurantId, code])
  @@map("coupons")
}

model Offer {
  id                   String     @id @default(cuid())
  restaurantId         String
  title                String?
  name                 String?
  code                 String?
  description          String?
  type                 OfferType?
  discountType         String?
  value                Float
  minimumOrderValue    Int?
  minOrderPaise        Int?
  maximumDiscount      Int?
  maxDiscountPaise     Int?
  startDate            DateTime?
  startsAt             DateTime?
  endDate              DateTime?
  endsAt               DateTime?
  maxUses              Int?
  currentUses          Int        @default(0)
  isActive             Boolean    @default(true)
  active               Boolean    @default(true)
  applicableItems      String[]   @default([])
  applicableCategories String[]   @default([])
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("offers")
  @@index([restaurantId, active])
  @@index([restaurantId, startsAt, endsAt])
}

model Payment {
  id                String       @id @default(cuid())
  orderId           String
  userId            String
  restaurantId      String
  method            String
  provider          String
  amountPaise       Int
  status            PaymentStatus
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
  @@index([orderId])
  @@index([restaurantId, createdAt])
}

model Earning {
  id                      String     @id @default(cuid())
  restaurantId            String
  orderId                 String     @unique
  grossAmountPaise        Int
  platformCommissionPaise Int
  restaurantEarningPaise  Int
  settled                 Boolean    @default(false)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  restaurant              Restaurant @relation("earnings", fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("earnings")
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String
  restaurantId  String?
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@map("audit_logs")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
  CENTRAL_ADMIN
  OWNER
  KITCHEN_STAFF
}

enum RestaurantRole {
  OWNER
  ADMIN
  STAFF
}

enum CouponType {
  PERCENT
  FIXED
}

enum PaymentProvider {
  RAZORPAY
  PAYTM
  PHONEPE
  CASH
}

enum PaymentCollectionTiming {
  BEFORE_MEAL
  AFTER_MEAL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_PAID
}

enum SpiceLevel {
  NONE
  MILD
  MEDIUM
  HOT
  EXTRA_HOT
}

enum InvoiceMethod {
  EMAIL
  SMS
}

enum OfferType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
  FREE_DELIVERY
}

enum OnboardingStatus {
  PENDING_APPROVAL
  APPROVED
  SUSPENDED
}
