{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "src/**",
          "prisma/**",
          "public/**",
          "node_modules/.prisma/client/**"
        ]
      }
    },
    {
      "src": "api/ultra-minimal.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/test-simple.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/test-minimal-app.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/test-content-length.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/ultra-minimal",
      "dest": "/api/ultra-minimal.ts"
    },
    {
      "src": "/ultra-debug",
      "dest": "/api/ultra-minimal.ts"
    },
    {
      "src": "/test-simple",
      "dest": "/api/test-simple.ts"
    },
    {
      "src": "/test-debug",
      "dest": "/api/test-simple.ts"
    },
    {
      "src": "/test-minimal-app",
      "dest": "/api/test-minimal-app.ts"
    },
    {
      "src": "/test-content-length",
      "dest": "/api/test-content-length.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}